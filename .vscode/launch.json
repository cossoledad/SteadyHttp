{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SteadyHttpTester",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/TestModule/SteadyHttpTester/build/Debug/steady-http-tester",
      "args": ["${input:testFile}", "${input:uploadUrl}"],
      "cwd": "${workspaceFolder}/TestModule/SteadyHttpTester",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "SteadyHttpTester: build Debug",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "testFile",
      "type": "promptString",
      "description": "Absolute path of the file to upload"
    },
    {
      "id": "uploadUrl",
      "type": "promptString",
      "description": "Upload and download URL",
      "default": "http://127.0.0.1:18080/abc.txt"
    }
  ]
}
